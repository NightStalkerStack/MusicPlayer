<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MusicPlayer"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="&#x97F3;&#x4E50;&#x64AD;&#x653E;&#x5668;"
        Height="640"
        Width="980"
        MinHeight="520"
        MinWidth="780"
        Background="{DynamicResource WindowBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="8"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#101216" />
        <SolidColorBrush x:Key="SidebarBrush" Color="#171A20" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1B1F27" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#252A34" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#343B4D" />
        <SolidColorBrush x:Key="PlayerBarBrush" Color="#14171D" />
        <SolidColorBrush x:Key="CoverSurfaceBrush" Color="#101216" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F6FA" />
        <SolidColorBrush x:Key="MutedBrush" Color="#9AA3B2" />
        <SolidColorBrush x:Key="AccentBrush" Color="#5AA9FF" />
        <SolidColorBrush x:Key="ButtonBrush" Color="#242936" />
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2E3545" />
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#343B4D" />
        <SolidColorBrush x:Key="SliderActiveBrush" Color="#FF8A3D" />
        <SolidColorBrush x:Key="SliderTrackBrush" Color="#8B8F96" />
        <SolidColorBrush x:Key="SliderThumbOuterBrush" Color="#4B4E55" />
        <SolidColorBrush x:Key="SliderThumbStrokeBrush" Color="#FFB071" />

        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="BorderBrush" Value="#3A8DFF" />
        </Style>

        <Style x:Key="PlayerIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="21">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelHoverBrush}" />
                    <Setter Property="Opacity" Value="1" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayerPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerIconButtonStyle}">
            <Setter Property="Width" Value="58" />
            <Setter Property="Height" Value="58" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="Opacity" Value="1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root"
                              Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1"
                                                ScaleY="1" />
                            </Grid.RenderTransform>
                            <Ellipse x:Name="Ring"
                                     Width="54"
                                     Height="54"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#FF8A3D" Offset="0" />
                                        <GradientStop Color="#F05A5E" Offset="0.48" />
                                        <GradientStop Color="#8E2DE2" Offset="1" />
                                    </LinearGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse x:Name="Inner"
                                     Width="44"
                                     Height="44"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource PlayerBarBrush}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.95" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlayerModeButtonStyle" TargetType="Button" BasedOn="{StaticResource PlayerIconButtonStyle}">
            <Setter Property="Width" Value="42" />
        </Style>

        <Style x:Key="IconImageStyle" TargetType="Image">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="RenderOptions.BitmapScalingMode" Value="HighQuality" />
        </Style>

        <Style x:Key="TitleBarIconImageStyle" TargetType="Image" BasedOn="{StaticResource IconImageStyle}">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
        </Style>

        <Style x:Key="PlayerIconImageStyle" TargetType="Image" BasedOn="{StaticResource IconImageStyle}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
        </Style>

        <Style x:Key="PlayerPrimaryIconImageStyle" TargetType="Image" BasedOn="{StaticResource IconImageStyle}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
        </Style>

        <Style x:Key="PlayerProgressSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{DynamicResource SliderActiveBrush}" />
            <Setter Property="Background" Value="{DynamicResource SliderTrackBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        Background="{DynamicResource SliderActiveBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="22"
                                           Height="22"
                                           Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="18"
                                                             Height="18"
                                                             Fill="{DynamicResource SliderThumbOuterBrush}"
                                                             Opacity="0.95" />
                                                    <Ellipse Width="10"
                                                             Height="10"
                                                             Fill="{DynamicResource SliderActiveBrush}"
                                                             Stroke="{DynamicResource SliderThumbStrokeBrush}"
                                                             StrokeThickness="1" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4"
                                                        Background="{DynamicResource SliderTrackBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerVolumeSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="32" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}"
                              Background="Transparent">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3"
                                                        Background="{DynamicResource SliderActiveBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18"
                                           Height="18"
                                           Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="16"
                                                             Height="16"
                                                             Fill="{DynamicResource SliderThumbOuterBrush}"
                                                             Opacity="0.95" />
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             Fill="{DynamicResource SliderActiveBrush}"
                                                             Stroke="{DynamicResource SliderThumbStrokeBrush}"
                                                             StrokeThickness="1" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3"
                                                        Background="{DynamicResource SliderTrackBrush}"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#D7DCE5" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2B303A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D83B01" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarToggleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Margin" Value="14,5" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaylistNameTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder"
            local:AppTheme.Role="Window"
            Background="{DynamicResource WindowBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="132" />
            </Grid.RowDefinitions>

            <Border Grid.RowSpan="3"
                    Grid.Column="0"
                    local:AppTheme.Role="Sidebar"
                    Background="{DynamicResource SidebarBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel x:Name="SidebarTitlePanel"
                                    Grid.Column="0"
                                    Margin="18,0,0,0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="28"
                                    Height="28"
                                    local:AppTheme.Role="Accent"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="14">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="15"
                                           Text="&#x266A;" />
                            </Border>
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="&#x97F3;&#x4E50;&#x64AD;&#x653E;&#x5668;" />
                        </StackPanel>

                        <Button x:Name="SidebarToggleButton"
                                Grid.Column="1"
                                Margin="6,14,14,14"
                                Content="&#x2039;"
                                Style="{StaticResource SidebarToggleButtonStyle}"
                                ToolTip="&#x6536;&#x8D77;&#x4FA7;&#x680F;"
                                Click="SidebarToggleButton_Click" />
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="0,18,0,0">
                        <Button x:Name="HomeNavButton"
                                Tag="Home"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#x2302;"
                                           Width="34"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock x:Name="HomeNavLabel"
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Text="&#x4E3B;&#x9875;"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Grid x:Name="PlaylistGroupHeader" Margin="18,0,18,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#x6B4C;&#x5355;"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="1"
                                    Height="1"
                                    Margin="14,0,0,0"
                                    local:AppTheme.Role="BorderLine"
                                    Background="{DynamicResource PanelBorderBrush}"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <Border x:Name="CollapsedPlaylistDivider"
                                Height="1"
                                Margin="18,0,18,10"
                                local:AppTheme.Role="BorderLine"
                                Background="{DynamicResource PanelBorderBrush}"
                                Visibility="Collapsed" />

                        <StackPanel x:Name="PlaylistItemsPanel" />

                        <Button x:Name="AddPlaylistButton"
                                Style="{StaticResource NavButtonStyle}"
                                Click="AddPlaylistButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="+"
                                           Width="34"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock x:Name="AddPlaylistNavLabel"
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Text="&#x589E;&#x52A0;&#x6B4C;&#x5355;"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,14">
                        <Border Height="1"
                                Margin="18,0,18,10"
                                local:AppTheme.Role="BorderLine"
                                Background="{DynamicResource PanelBorderBrush}" />

                        <Button x:Name="SettingsNavButton"
                                Tag="Settings"
                                Margin="14,0,14,0"
                                Style="{StaticResource NavButtonStyle}"
                                Click="NavButton_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#x2699;"
                                           Width="34"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center" />
                                <TextBlock x:Name="SettingsNavLabel"
                                           Grid.Column="1"
                                           Margin="10,0,0,0"
                                           Text="&#x8BBE;&#x7F6E;"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="0"
                  Grid.Column="1"
                  local:AppTheme.Role="Window"
                  Background="{DynamicResource WindowBrush}">
                <StackPanel HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Style="{StaticResource TitleBarButtonStyle}"
                            ToolTip="&#x6700;&#x5C0F;&#x5316;"
                            Click="MinimizeButton_Click">
                        <Image Source="Assets/Icons/window-minimize.png"
                               Style="{StaticResource TitleBarIconImageStyle}" />
                    </Button>
                    <Button x:Name="MaximizeButton"
                            Style="{StaticResource TitleBarButtonStyle}"
                            ToolTip="&#x6700;&#x5927;&#x5316;"
                            Click="MaximizeButton_Click">
                        <Image Source="Assets/Icons/window-maximize.png"
                               Style="{StaticResource TitleBarIconImageStyle}" />
                    </Button>
                    <Button Style="{StaticResource CloseButtonStyle}"
                            ToolTip="&#x5173;&#x95ED;"
                            Click="CloseButton_Click">
                        <Image Source="Assets/Icons/window-close.png"
                               Style="{StaticResource TitleBarIconImageStyle}" />
                    </Button>
                </StackPanel>
            </Grid>

            <ContentControl x:Name="MainContentHost"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="32,20,32,24" />

            <Border Grid.Row="2"
                    Grid.Column="1"
                    local:AppTheme.Role="PlayerBar"
                    Background="{DynamicResource PlayerBarBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="26,10,26,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CurrentTimeTextBlock"
                                   Text="00:00"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="ProgressSlider"
                                Grid.Column="1"
                                Margin="12,0"
                                Minimum="0"
                                Maximum="1"
                                Style="{StaticResource PlayerProgressSliderStyle}"
                                ValueChanged="ProgressSlider_ValueChanged"
                                PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                                PreviewMouseMove="ProgressSlider_PreviewMouseMove"
                                PreviewMouseUp="ProgressSlider_PreviewMouseUp" />
                        <TextBlock x:Name="TotalTimeTextBlock"
                                   Grid.Column="2"
                                   Text="00:00"
                                   Foreground="{DynamicResource MutedBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Width="52"
                                    Height="52"
                                    HorizontalAlignment="Left"
                                    local:AppTheme.Role="CoverSurface"
                                    Background="{DynamicResource CoverSurfaceBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <TextBlock Text="&#x266B;"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="24"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="PlayerSongTitleTextBlock"
                                           Text="&#x672A;&#x9009;&#x62E9;&#x6B4C;&#x66F2;"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <StackPanel Margin="0,6,0,0"
                                            Orientation="Horizontal">
                                    <TextBlock x:Name="PlayerArtistTextBlock"
                                               Text="&#x672A;&#x77E5;&#x6B4C;&#x624B;"
                                               Foreground="{DynamicResource MutedBrush}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="  /  "
                                               Foreground="#606A7B"
                                               FontSize="13" />
                                    <TextBlock x:Name="PlayerAlbumTextBlock"
                                               Text="&#x672A;&#x77E5;&#x5531;&#x7247;"
                                               Foreground="{DynamicResource MutedBrush}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Button x:Name="PreviousButton"
                                    Style="{StaticResource PlayerIconButtonStyle}"
                                    IsEnabled="False"
                                    ToolTip="&#x4E0A;&#x4E00;&#x9996;"
                                    Click="PreviousButton_Click">
                                <Image x:Name="PreviousIcon"
                                       Style="{StaticResource PlayerIconImageStyle}" />
                            </Button>
                            <Button x:Name="PlayPauseButton"
                                    Margin="12,0"
                                    Style="{StaticResource PlayerPrimaryButtonStyle}"
                                    IsEnabled="False"
                                    ToolTip="&#x64AD;&#x653E; / &#x6682;&#x505C;"
                                    Click="PlayPauseButton_Click">
                                <Image x:Name="PlayPauseIcon"
                                       Source="Assets/Icons/play.png"
                                       Margin="2,0,0,0"
                                       Style="{StaticResource PlayerPrimaryIconImageStyle}" />
                            </Button>
                            <Button x:Name="NextButton"
                                    Style="{StaticResource PlayerIconButtonStyle}"
                                    IsEnabled="False"
                                    ToolTip="&#x4E0B;&#x4E00;&#x9996;"
                                    Click="NextButton_Click">
                                <Image x:Name="NextIcon"
                                       Style="{StaticResource PlayerIconImageStyle}" />
                            </Button>
                        </StackPanel>

                        <Grid Grid.Column="2"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="138" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="PlayModeButton"
                                    Style="{StaticResource PlayerModeButtonStyle}"
                                    ToolTip="&#x5207;&#x6362;&#x5FAA;&#x73AF;&#x6A21;&#x5F0F;"
                                    Click="PlayModeButton_Click">
                                <Image x:Name="PlayModeIcon"
                                       Source="Assets/Icons/repeat.png"
                                       Style="{StaticResource PlayerIconImageStyle}" />
                            </Button>
                            <Button x:Name="MuteButton"
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource PlayerIconButtonStyle}"
                                    ToolTip="&#x9759;&#x97F3;"
                                    Click="MuteButton_Click">
                                <Image x:Name="MuteIcon"
                                       Source="Assets/Icons/volume.png"
                                       Style="{StaticResource PlayerIconImageStyle}" />
                            </Button>
                            <Slider x:Name="VolumeSlider"
                                    Grid.Column="2"
                                    Width="128"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Minimum="0"
                                    Maximum="1"
                                    Style="{StaticResource PlayerVolumeSliderStyle}"
                                    Value="0.7"
                                    PreviewMouseDown="VolumeSlider_PreviewMouseDown"
                                    PreviewMouseMove="VolumeSlider_PreviewMouseMove"
                                    PreviewMouseUp="VolumeSlider_PreviewMouseUp"
                                    ValueChanged="VolumeSlider_ValueChanged" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>


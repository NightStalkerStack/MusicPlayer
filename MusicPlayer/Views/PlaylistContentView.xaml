<UserControl x:Class="MusicPlayer.Views.PlaylistContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MusicPlayer">
    <UserControl.Resources>
        <Style x:Key="PlaylistActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="MinWidth" Value="116" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#242A35" />
            <Setter Property="BorderBrush" Value="#343C4C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F4F6FA" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2E3646" />
                    <Setter Property="BorderBrush" Value="#465166" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryPlaylistActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PlaylistActionButtonStyle}">
            <Setter Property="Background" Value="#2F80ED" />
            <Setter Property="BorderBrush" Value="#3A8DFF" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3C8CF4" />
                    <Setter Property="BorderBrush" Value="#5AA9FF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Border Width="3"
                                    HorizontalAlignment="Center"
                                    Background="#6F7888"
                                    CornerRadius="2" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0,2" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Width="180"
                    Height="180"
                    MinWidth="0"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Click="CoverButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#0D0F13"
                                BorderBrush="#2A303C"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Grid>
                    <Image x:Name="CoverImage"
                           Stretch="UniformToFill"
                           Visibility="Collapsed" />
                    <StackPanel x:Name="CoverPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="&#x266B;"
                                   HorizontalAlignment="Center"
                                   FontSize="42"
                                   Foreground="#5AA9FF" />
                        <TextBlock Text="&#x6B4C;&#x5355;&#x5C01;&#x9762;"
                                   Margin="0,12,0,0"
                                   Foreground="{DynamicResource MutedBrush}" />
                    </StackPanel>
                </Grid>
            </Button>

            <StackPanel Grid.Column="1" Margin="28,0,0,0">
                <TextBlock x:Name="PlaylistTitleTextBlock"
                           Text="&#x6682;&#x65E0;&#x6B4C;&#x5355;"
                           FontSize="32"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="TrackCountTextBlock"
                           Text="0 &#x9996;&#x6B4C;"
                           Margin="0,12,0,0"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="15" />

                <WrapPanel Margin="0,28,0,0">
                    <Button Style="{StaticResource PrimaryPlaylistActionButtonStyle}"
                            Click="PlayMusicButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x25B6;"
                                       Margin="0,0,8,0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#x64AD;&#x653E;&#x97F3;&#x4E50;"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource PlaylistActionButtonStyle}"
                            Click="AddMusicButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+"
                                       Margin="0,0,8,0"
                                       FontSize="18"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#x6DFB;&#x52A0;&#x97F3;&#x4E50;"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Margin="12,0,0,0"
                            Style="{StaticResource PlaylistActionButtonStyle}"
                            Click="ClearPlaylistButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2715;"
                                       Margin="0,0,8,0"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="&#x6E05;&#x7A7A;&#x5217;&#x8868;"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,32,0,0"
                Padding="18"
                local:AppTheme.Role="Panel"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <TextBlock x:Name="EmptyTracksTextBlock"
                           Text="&#x6682;&#x65E0;&#x97F3;&#x4E50;&#xFF0C;&#x70B9;&#x51FB;&#x201C;&#x6DFB;&#x52A0;&#x97F3;&#x4E50;&#x201D;&#x5F00;&#x59CB;&#x6784;&#x5EFA;&#x6B4C;&#x5355;"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedBrush}" />

                <DataGrid x:Name="TrackDataGrid"
                          Visibility="Collapsed"
                          AutoGenerateColumns="False"
                          Background="Transparent"
                          BorderThickness="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          CanUserSortColumns="False"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          FocusVisualStyle="{x:Null}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          HorizontalGridLinesBrush="Transparent"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          RowHeight="54"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          VerticalGridLinesBrush="Transparent"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Resources>
                        <Style x:Key="TrackHeaderStyle" TargetType="DataGridColumnHeader">
                            <Setter Property="Height" Value="44" />
                            <Setter Property="Padding" Value="16,0" />
                            <Setter Property="Background" Value="{DynamicResource PanelBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                              RecognizesAccessKey="True" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="CenteredTrackHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource TrackHeaderStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>

                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource TrackHeaderStyle}" />

                        <Style x:Key="TrackCellStyle" TargetType="DataGridCell">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <ContentPresenter VerticalAlignment="Center" />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="LeftTrackTextStyle" TargetType="TextBlock">
                            <Setter Property="Margin" Value="16,0" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        </Style>

                        <Style x:Key="MutedTrackTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LeftTrackTextStyle}">
                            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                        </Style>

                        <Style x:Key="TitleTrackTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LeftTrackTextStyle}">
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                        </Style>

                        <Style x:Key="DurationTrackTextStyle" TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Setter Property="AllowDrop" Value="True" />
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TrackItem_PreviewMouseLeftButtonDown" />
                            <EventSetter Event="MouseLeftButtonUp" Handler="TrackItem_MouseLeftButtonUp" />
                            <EventSetter Event="MouseRightButtonUp" Handler="TrackItem_MouseRightButtonUp" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRow">
                                        <Border x:Name="RowBackground"
                                                Margin="0,4"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <SelectiveScrollingGrid>
                                                <SelectiveScrollingGrid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </SelectiveScrollingGrid.ColumnDefinitions>
                                                <DataGridCellsPresenter Grid.Column="0"
                                                                        ItemsPanel="{TemplateBinding ItemsPanel}" />
                                                <DataGridDetailsPresenter Grid.Column="0"
                                                                          SelectiveScrollingGrid.SelectiveScrollingOrientation="Vertical"
                                                                          Visibility="{TemplateBinding DetailsVisibility}" />
                                            </SelectiveScrollingGrid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource PanelHoverBrush}" />
                                                <Setter TargetName="RowBackground" Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="RowBackground" Property="Background" Value="{DynamicResource PanelHoverBrush}" />
                                                <Setter TargetName="RowBackground" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="&#x5E8F;&#x53F7;"
                                            Binding="{Binding Index}"
                                            Width="80"
                                            HeaderStyle="{StaticResource TrackHeaderStyle}"
                                            CellStyle="{StaticResource TrackCellStyle}"
                                            ElementStyle="{StaticResource MutedTrackTextStyle}" />
                        <DataGridTextColumn Header="&#x6B4C;&#x66F2;&#x540D;"
                                            Binding="{Binding Title}"
                                            Width="2*"
                                            HeaderStyle="{StaticResource TrackHeaderStyle}"
                                            CellStyle="{StaticResource TrackCellStyle}"
                                            ElementStyle="{StaticResource TitleTrackTextStyle}" />
                        <DataGridTextColumn Header="&#x5531;&#x7247;"
                                            Binding="{Binding Album}"
                                            Width="2*"
                                            HeaderStyle="{StaticResource TrackHeaderStyle}"
                                            CellStyle="{StaticResource TrackCellStyle}"
                                            ElementStyle="{StaticResource MutedTrackTextStyle}" />
                        <DataGridTextColumn Header="&#x65F6;&#x957F;"
                                            Binding="{Binding DurationText}"
                                            Width="110"
                                            HeaderStyle="{StaticResource CenteredTrackHeaderStyle}"
                                            CellStyle="{StaticResource TrackCellStyle}"
                                            ElementStyle="{StaticResource DurationTrackTextStyle}" />
                        <DataGridTextColumn Header="&#x6B4C;&#x624B;"
                                            Binding="{Binding Artist}"
                                            Width="2*"
                                            HeaderStyle="{StaticResource TrackHeaderStyle}"
                                            CellStyle="{StaticResource TrackCellStyle}"
                                            ElementStyle="{StaticResource MutedTrackTextStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


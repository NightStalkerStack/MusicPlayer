<UserControl x:Class="MusicPlayer.Views.NowPlayingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MusicPlayer">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel>
                <TextBlock Text="&#x6B63;&#x5728;&#x64AD;&#x653E;"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="&#x6253;&#x5F00;&#x672C;&#x5730;&#x97F3;&#x9891;&#x6587;&#x4EF6;&#x5E76;&#x5F00;&#x59CB;&#x64AD;&#x653E;"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource MutedBrush}" />
            </StackPanel>
            <Button Content="&#x6253;&#x5F00;&#x6587;&#x4EF6;"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Top"
                    Click="OpenFileButton_Click" />
        </DockPanel>

        <Border Grid.Row="1"
                Margin="0,28,0,0"
                Padding="32"
                local:AppTheme.Role="Panel"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="&#x5F53;&#x524D;&#x6B4C;&#x66F2;"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="13" />
                <TextBlock x:Name="SongNameTextBlock"
                           Text="&#x8BF7;&#x9009;&#x62E9;&#x4E00;&#x4E2A;&#x97F3;&#x9891;&#x6587;&#x4EF6;"
                           Margin="0,12,0,0"
                           FontSize="30"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SongPathTextBlock"
                           Text=""
                           Margin="0,10,0,0"
                           Foreground="{DynamicResource MutedBrush}"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>


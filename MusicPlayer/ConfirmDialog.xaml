<Window x:Class="MusicPlayer.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MusicPlayer"
        Title="Confirm"
        Width="380"
        SizeToContent="Height"
        Background="Transparent"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Border local:AppTheme.Role="Panel"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <Border Width="34"
                        Height="34"
                        DockPanel.Dock="Left"
                        Background="{DynamicResource DangerSubtleBrush}"
                        CornerRadius="17">
                    <TextBlock Text="!"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource DangerTextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold" />
                </Border>

                <TextBlock x:Name="TitleTextBlock"
                           Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
            </DockPanel>

            <TextBlock x:Name="MessageTextBlock"
                       Grid.Row="1"
                       Margin="48,14,0,24"
                       Foreground="{DynamicResource MutedBrush}"
                       FontSize="14"
                       LineHeight="21"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="&#x53D6;&#x6D88;"
                        Style="{StaticResource DialogButtonStyle}"
                        Click="CancelButton_Click" />
                <Button x:Name="ConfirmButton"
                        Content="&#x786E;&#x8BA4;"
                        Margin="10,0,0,0"
                        Style="{StaticResource DangerDialogButtonStyle}"
                        Click="ConfirmButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>


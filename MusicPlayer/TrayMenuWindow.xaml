<Window x:Class="MusicPlayer.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="190"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Topmost="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="TrayMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#F2F2F2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2F2F2F" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#383838" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="8"
            Padding="6"
            Background="#242424"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="10"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              Direction="270"
                              Opacity="0.35"
                              ShadowDepth="4"
                              Color="#000000" />
        </Border.Effect>

        <StackPanel>
            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="PreviousButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M13,3 L6,8 L13,13 Z M4,3 L4,13" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="&#x4E0A;&#x4E00;&#x9996;" />
                </Grid>
            </Button>

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="PlayPauseButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path x:Name="PlayPauseIconPath"
                          Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M4,2 L13,8 L4,14 Z" />
                    <TextBlock x:Name="PlayPauseTextBlock"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="&#x64AD;&#x653E;" />
                </Grid>
            </Button>

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="NextButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          StrokeLineJoin="Round"
                          Data="M3,3 L10,8 L3,13 Z M12,3 L12,13" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="&#x4E0B;&#x4E00;&#x9996;" />
                </Grid>
            </Button>

            <Border Height="1"
                    Margin="8,4"
                    Background="#3A3A3A" />

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="ShowWindowButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M3,4 L13,4 L13,12 L3,12 Z M5,2 L15,2 L15,10" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="&#x663E;&#x793A;&#x4E3B;&#x7A97;&#x53E3;" />
                </Grid>
            </Button>

            <Border Height="1"
                    Margin="8,4"
                    Background="#3A3A3A" />

            <Button Style="{StaticResource TrayMenuButtonStyle}"
                    Click="ExitButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Path Width="16"
                          Height="16"
                          Stretch="Uniform"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Data="M8,2 L8,8 M4.5,4.8 C3.2,5.8 2.5,7.3 2.5,9 C2.5,12 5,14.5 8,14.5 C11,14.5 13.5,12 13.5,9 C13.5,7.3 12.8,5.8 11.5,4.8" />
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Text="&#x9000;&#x51FA;" />
                </Grid>
            </Button>
        </StackPanel>
    </Border>
</Window>
